{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GraphGen Configuration Schema",
  "description": "GraphGen数据生成任务配置参数",
  "type": "object",
  "required": ["synthesizer_model", "synthesizer_url", "api_key", "upload_file"],
  "properties": {
    "if_trainee_model": {
      "type": "boolean",
      "default": false,
      "title": "启用Trainee模型",
      "description": "是否使用第二个模型进行quiz和judge步骤"
    },
    "tokenizer": {
      "type": "string",
      "default": "cl100k_base",
      "title": "Tokenizer模型",
      "description": "用于token计数的tokenizer名称"
    },
    "synthesizer_model": {
      "type": "string",
      "minLength": 1,
      "title": "Synthesizer模型",
      "description": "用于构建知识图谱和生成数据的主模型",
      "examples": ["Qwen/Qwen2.5-7B-Instruct", "gpt-4o-mini"]
    },
    "synthesizer_url": {
      "type": "string",
      "format": "uri",
      "title": "Synthesizer API地址",
      "description": "OpenAI兼容的API端点",
      "examples": ["https://api.siliconflow.cn/v1", "https://api.openai.com/v1"]
    },
    "api_key": {
      "type": "string",
      "minLength": 1,
      "title": "API密钥",
      "description": "Synthesizer模型的API密钥"
    },
    "trainee_model": {
      "type": "string",
      "title": "Trainee模型",
      "description": "用于quiz和judge的第二个模型（可选）"
    },
    "trainee_url": {
      "type": "string",
      "format": "uri",
      "title": "Trainee API地址"
    },
    "trainee_api_key": {
      "type": "string",
      "title": "Trainee API密钥"
    },
    "chunk_size": {
      "type": "integer",
      "minimum": 256,
      "maximum": 4096,
      "default": 1024,
      "title": "分块大小",
      "description": "文本分块的token数量"
    },
    "chunk_overlap": {
      "type": "integer",
      "minimum": 0,
      "maximum": 500,
      "default": 100,
      "title": "分块重叠",
      "description": "相邻分块之间的重叠token数"
    },
    "quiz_samples": {
      "type": "integer",
      "minimum": 1,
      "default": 2,
      "title": "Quiz样本数",
      "description": "每个描述生成的quiz问题数量"
    },
    "partition_method": {
      "type": "string",
      "enum": ["dfs", "bfs", "leiden", "ece"],
      "default": "ece",
      "title": "分区方法",
      "description": "知识图谱分区算法"
    },
    "dfs_max_units": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 5,
      "title": "DFS最大单元数",
      "description": "DFS分区方法的每个社区最大单元数"
    },
    "bfs_max_units": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 5,
      "title": "BFS最大单元数",
      "description": "BFS分区方法的每个社区最大单元数"
    },
    "leiden_max_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20,
      "title": "Leiden最大社区规模",
      "description": "Leiden分区方法的最大社区规模"
    },
    "leiden_use_lcc": {
      "type": "boolean",
      "default": false,
      "title": "使用最大连通分量",
      "description": "Leiden分区方法是否使用最大连通分量"
    },
    "leiden_random_seed": {
      "type": "integer",
      "default": 42,
      "title": "随机种子",
      "description": "Leiden分区方法的随机种子"
    },
    "ece_max_units": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20,
      "title": "ECE最大单元数",
      "description": "ECE分区方法的每个社区最大单元数"
    },
    "ece_min_units": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 3,
      "title": "ECE最小单元数",
      "description": "ECE分区方法的每个社区最小单元数"
    },
    "ece_max_tokens": {
      "type": "integer",
      "minimum": 512,
      "maximum": 20480,
      "default": 10240,
      "title": "ECE最大token数",
      "description": "ECE分区方法的每个社区最大token数"
    },
    "ece_unit_sampling": {
      "type": "string",
      "enum": ["random", "max_loss", "min_loss"],
      "default": "random",
      "title": "ECE单元采样策略",
      "description": "ECE分区方法的单元采样策略"
    },
    "mode": {
      "type": "string",
      "enum": [
        "atomic",
        "multi_hop",
        "aggregated",
        "CoT",
        "multi_choice",
        "multi_answer",
        "fill_in_blank",
        "true_false"
      ],
      "default": "aggregated",
      "title": "生成模式",
      "description": "QA对生成的类型"
    },
    "data_format": {
      "type": "string",
      "enum": ["Alpaca", "Sharegpt", "ChatML"],
      "default": "Alpaca",
      "title": "输出格式",
      "description": "生成数据的格式"
    },
    "rpm": {
      "type": "integer",
      "minimum": 10,
      "maximum": 10000,
      "default": 1000,
      "title": "每分钟请求数",
      "description": "API速率限制（Requests Per Minute）"
    },
    "tpm": {
      "type": "integer",
      "minimum": 5000,
      "maximum": 5000000,
      "default": 50000,
      "title": "每分钟token数",
      "description": "API速率限制（Tokens Per Minute）"
    },
    "upload_file": {
      "type": "string",
      "title": "上传文件路径",
      "description": "输入数据文件的路径"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "if_trainee_model": {"const": true}
        }
      },
      "then": {
        "required": ["trainee_model", "trainee_url", "trainee_api_key"]
      }
    }
  ]
}
